# --- Import Status Icon Textures ---
import image name="CC Icon Happy" filepath="textures/effect/happy.png" comment="Source positive environment icon"
import image name="CC Icon Sad" filepath="textures/effect/sad.png" comment="Source negative environment icon"
import image name="CC Icon Coin" filepath="textures/effect/coinBuff.png" comment="Source economic bonus icon"
import image name="CC Icon Human" filepath="textures/effect/humanBuff.png" comment="Source human bonus icon"
import image name="CC Icon Human Down" filepath="textures/effect/humanDebuff.png" comment="Source human debuff icon"
import image name="CC Icon Miss Road" filepath="textures/effect/miss-road.png" comment="Source missing road icon"
import image name="CC Icon Miss Power" filepath="textures/effect/miss-power.png" comment="Source missing power icon"
import image name="CC Icon Miss Population" filepath="textures/effect/miss-population.png" comment="Source missing population icon"
import image name="CC Icon Over Population" filepath="textures/effect/over-population.png" comment="Source over population icon"
import image name="CC Icon Pollution Up" filepath="textures/effect/pollutionUp.png" comment="Source pollution increase icon"
import image name="CC Icon Pollution Down" filepath="textures/effect/pollutionDown.png" comment="Source pollution decrease icon"
import image name="CC Icon Pollution Lower" filepath="textures/effect/pollutionlowerBuff.png" comment="Source pollution reduction icon"
import image name="CC Icon Power" filepath="textures/effect/power.png" comment="Source power output icon"
import image name="CC Icon Power Boost" filepath="textures/effect/powerBuff.png" comment="Source power boost icon"
import image name="CC Icon Upgrade" filepath="textures/effect/upgrade.png" comment="Source upgrade icon"
import image name="CC Icon Angry" filepath="textures/effect/angry.png" comment="Source angry warning icon"

# --- Import Audio ---
import audio name="CC Track 1" filepath="audio/song01.mp3" comment="Source background music track 1"
import audio name="CC Track 2" filepath="audio/song02.mp3" comment="Source background music track 2"

# --- Import Behavior ---
import behavior name="CC City Game" filepath="behaviors/ccCityGame.yaml" comment="CubeCity runtime: grid, simulation, interaction, camera, HUD, map, and music"

# --- Scene Settings ---
scene background type=Gradient gradient="linear-gradient(180deg, #7392bb 0%, #3b5279 100%)"
scene fog type=none
scene lighting ambient={skyColor:#e7f2ff,groundColor:#64748b,intensity:1.0}
update "Directional Light" position=10,14,8
light "Directional Light" intensity=2.4 color=#fff2d1 castShadow=true shadowMapSize=2048
render settings useShadows=true useInstancing=false
game settings enabled=true showHUD=false maxScore=0

# --- Player Anchor ---
add group name="Player" position=0,0,0
update Player tag=Player

# --- Camera ---
camera "DefaultCamera" cameraType=NONE fov=28 near=0.01 far=250

# --- Runtime Systems ---
behavior attach Player behaviorId=cc.cityGame
