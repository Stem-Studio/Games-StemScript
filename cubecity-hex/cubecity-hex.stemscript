# --- Hide source/template models ---
# These are imported only as asset sources; the cc.cityGame behavior spawns
# buildings at runtime via erth.asset.model.createInstance(), so the imported
# template objects must be hidden in play (otherwise they pile up at the origin).
update "CC House L1" objectSettings={gameVisibility:false}
update "CC House L2" objectSettings={gameVisibility:false}
update "CC House L3" objectSettings={gameVisibility:false}
update "CC House2 L1" objectSettings={gameVisibility:false}
